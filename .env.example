# .env.example — copy this file to .env and fill in your credentials
# -----------------------------------------------------------------------
# cp .env.example .env        (Linux / macOS)
# Copy-Item .env.example .env (Windows PowerShell)
# -----------------------------------------------------------------------
# The .env file is gitignored and must never be committed to source control.

# Azure OpenAI — required
AZURE_OPENAI_ENDPOINT=https://<your-resource-name>.openai.azure.com
AZURE_OPENAI_API_KEY=<your-api-key>

# Azure OpenAI — optional (defaults to 2024-02-01 if not set)
AZURE_OPENAI_API_VERSION=2024-02-01

# Azure OpenAI — deployment names
AZURE_CHAT_DEPLOYMENT_NAME=gpt-4o-mini
AZURE_EMBEDDING_DEPLOYMENT_NAME=text-embedding-ada-002
